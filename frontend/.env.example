# Firebase Web app config (Project settings → General → Your apps → Web app).
# These are public client keys (safe to ship in a SPA); access is gated by
# Firebase Auth + Firestore security rules, not by hiding these.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=tokyo-gemini-ai-hackathon.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tokyo-gemini-ai-hackathon
VITE_FIREBASE_STORAGE_BUCKET=tokyo-gemini-ai-hackathon.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Named Firestore database (asia-northeast1), not the "(default)" db.
VITE_FIREBASE_DATABASE_ID=sourcingsentinel

# Backend base URL. Leave EMPTY in Phase 2 to use the built-in mock client.
# Set to the deployed FastAPI / Cloud Run URL in Phase 4 to use the real agent.
VITE_API_BASE=
